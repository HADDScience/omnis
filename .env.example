# ─── Database ────────────────────────────────────────────
# Docker Compose 사용 시 docker-compose.yml의 POSTGRES_PASSWORD와 일치시킬 것
DATABASE_URL="postgresql://omnis:CHANGE_ME@localhost:5432/omnis"

# ─── NextAuth ────────────────────────────────────────────
# 비밀키 생성: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_OPENSSL_RAND_BASE64_32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Gemini API ──────────────────────────────────────────
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=""

# ─── Seed / E2E ──────────────────────────────────────────
# 시드 사용자 5명에 적용될 공통 비밀번호 (개발용)
SEED_PASSWORD="changeme"
# Playwright E2E 로그인 시 사용
E2E_PASSWORD="changeme"
